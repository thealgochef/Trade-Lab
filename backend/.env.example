# Backend server
TRADE_LAB_BACKEND_HOST=127.0.0.1
TRADE_LAB_BACKEND_PORT=8001
TRADE_LAB_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
# Optional operator token for non-local/no-origin operator clients.
# Never commit or share a real token.
TRADE_LAB_OPERATOR_TOKEN=

# Databento market data (placeholders only; never commit real credentials)
TRADE_LAB_DATABENTO_API_KEY=
# Explicit paid-data opt-in required before manual live start can succeed.
# Deliberately change this to true only when ready for live validation.
TRADE_LAB_DATABENTO_LIVE_ENABLED=false
TRADE_LAB_DATABENTO_DATASET=GLBX.MDP3
TRADE_LAB_DATABENTO_REQUESTED_SYMBOL=NQ.c.0
TRADE_LAB_DATABENTO_STYPE_IN=continuous
TRADE_LAB_DATABENTO_TRADE_SCHEMA=trades
TRADE_LAB_DATABENTO_QUOTE_SCHEMA=mbp-1
TRADE_LAB_DATABENTO_CONTEXT_SCHEMAS=definition,status,statistics

# Replay/catalog defaults
TRADE_LAB_MARKET_DATA_DATASET=GLBX.MDP3
TRADE_LAB_MARKET_DATA_SCHEMA=trades
TRADE_LAB_FRONT_MONTH_SYMBOL=NQ.c.0
TRADE_LAB_INSTRUMENT_ROOT=NQ

# Live warm-up seeding: on live start, pre-fill the chart with the last N completed
# sessions of front-month tick bars from the Databento Historical API (uses the same
# API key). Set TRADE_LAB_SEED_ENABLED=false to disable.
TRADE_LAB_SEED_ENABLED=true
TRADE_LAB_SEED_LOOKBACK_DAYS=3
TRADE_LAB_SEED_MAX_BARS_PER_TIMEFRAME=2500

# Local data paths
TRADE_LAB_DATA_PATH=C:\Users\gonza\Documents\Trade-Dashboard\data\databento\NQ
TRADE_LAB_MODELS_PATH=C:\Users\gonza\Documents\Claude-Quant-Lab\models
